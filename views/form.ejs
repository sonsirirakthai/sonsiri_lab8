<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <title><%= product ? 'แก้ไขสินค้า' : 'เพิ่มสินค้าใหม่' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<div class="container mt-5 d-flex justify-content-center">
    <div class="card shadow-sm w-50">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0"><%= product ? 'แก้ไขสินค้า' : 'เพิ่มสินค้าใหม่' %></h4>
        </div>
        <div class="card-body">
            <form action="<%= product ? '/edit/' + product.id : '/add' %>" method="POST" enctype="multipart/form-data">
                
                <div class="mb-3">
                    <label class="form-label">ชื่อสินค้า</label>
                    <input type="text" name="name" class="form-control" value="<%= product ? product.name : '' %>" required>
                </div>

                <div class="mb-3">
                    <label class="form-label">หมวดหมู่</label>
                    <input type="text" name="category" class="form-control" value="<%= product ? product.category : '' %>">
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">ราคา</label>
                        <input type="number" name="price" class="form-control" min="0" step="0.01" value="<%= product ? product.price : '' %>" required>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">จำนวนสต็อก</label>
                        <input type="number" name="stock" class="form-control" min="0" value="<%= product ? product.stock : '' %>" required>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">รูปภาพสินค้า</label>
                    <input type="file" name="image" id="imageInput" class="form-control" accept="image/*">
                    
                    <% if(product && product.image) { %>
                        <input type="hidden" name="old_image" value="<%= product.image %>">
                    <% } %>
                </div>

                <div class="mb-3 text-center">
                    <img id="preview" 
                         src="<%= (product && product.image) ? '/uploads/' + product.image : '' %>" 
                         class="img-thumbnail <%= (product && product.image) ? '' : 'd-none' %>" 
                         style="max-width: 200px;">
                </div>

                <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                    <a href="/" class="btn btn-secondary">ยกเลิก</a>
                    <button type="submit" class="btn btn-success">บันทึกข้อมูล</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // JS สำหรับโบนัสพิเศษ (Image Preview ทันทีที่เลือกไฟล์)
    document.getElementById('imageInput').addEventListener('change', function(event) {
        const [file] = event.target.files;
        if (file) {
            const preview = document.getElementById('preview');
            preview.src = URL.createObjectURL(file);
            preview.classList.remove('d-none');
        }
    });
</script>
</body>
</html>